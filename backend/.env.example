DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=pdfcraft.settings.development
CORS_ALLOWED_ORIGINS=http://localhost:5173
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pdfcraft
DB_USER=postgres
DB_PASSWORD=your-password-here

# Production (Neon) - set DATABASE_URL in production environment
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/pdfcraft?sslmode=require
